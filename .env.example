# GitHub API Token
# Required for GitHubEmbed component to fetch repository data
# Get token: https://github.com/settings/personal-access-tokens/new
# Scope: public_repo (read-only access to public repositories)
# Without token: limited to 60 requests/hour
# With token: 5000 requests/hour
GITHUB_TOKEN=ghp_your_token_here

# Optional: Google Site Verification
# PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here
