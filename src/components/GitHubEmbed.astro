---
/**
 * GitHubEmbed — Display a GitHub repository card inline in MDX posts.
 * 
 * Usage in .mdx files:
 *   import GitHubEmbed from '../components/GitHubEmbed.astro';
 *   <GitHubEmbed repo="username/repo-name" />
 */

type Props = {
  repo: string;
};

interface GitHubRepo {
  name: string;
  description: string | null;
  html_url: string;
  stargazers_count: number;
  language: string | null;
}

const { repo } = Astro.props;

// Validate repo format
if (!repo || !repo.includes("/")) {
  throw new Error(`GitHubEmbed: Invalid repo format. Use "username/repo-name"`);
}

// Fetch repository data from GitHub API at build time
let repoData: GitHubRepo | null = null;
let languages: string[] = [];
let error: string | null = null;

try {
  const headers: HeadersInit = {
    Accept: "application/vnd.github.v3+json",
  };
  
  // Use GitHub token for authenticated requests (5000/hour instead of 60/hour)
  const token = import.meta.env.GITHUB_TOKEN;
  if (token) {
    headers.Authorization = `token ${token}`;
    console.log(`[GitHubEmbed] Using authenticated GitHub API request for ${repo}`);
  } else {
    console.log(`[GitHubEmbed] No GITHUB_TOKEN found, using unauthenticated request for ${repo} (limited to 60 requests/hour)`);
  }
  
  const response = await fetch(`https://api.github.com/repos/${repo}`, { headers });
  
  if (!response.ok) {
    error = `Repository not found (${response.status})`;
  } else {
    repoData = await response.json();
    
    // Fetch languages used in the repository
    try {
      const langResponse = await fetch(`https://api.github.com/repos/${repo}/languages`, { headers });
      if (langResponse.ok) {
        const langData = await langResponse.json();
        // Sort languages by byte count (descending) and get top 2
        languages = Object.entries(langData)
          .sort(([, bytesA], [, bytesB]) => (bytesB as number) - (bytesA as number))
          .slice(0, 2)
          .map(([lang]) => lang);
      }
    } catch (e) {
      // If languages fetch fails, we still have the primary language from repoData
      console.warn(`[GitHubEmbed] Failed to fetch languages for ${repo}`);
    }
  }
} catch (e) {
  error = `Failed to fetch repository: ${String(e)}`;
}

// Format star count (1000+ → "1K")
const formatStars = (count: number): string => {
  if (count >= 1000) return `${(count / 1000).toFixed(1)}K`;
  return count.toString();
};

// Get language color
const getLanguageColor = (language: string | null): string => {
  const colors: Record<string, string> = {
    TypeScript: "#3178c6",
    JavaScript: "#f1e05a",
    Python: "#3572a5",
    Rust: "#dea584",
    Go: "#00add8",
    Java: "#b07219",
  };
  return colors[language || ""] || "#888888";
};
---

{error ? (
  <div class="not-prose my-4 rounded-xl border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-400">
    <strong>GitHubEmbed Error:</strong> {error}
  </div>
) : repoData ? (
  <a
    href={repoData.html_url}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      "github-embed not-prose block my-6 rounded-xl p-5",
      "border border-slate-200/60 bg-gradient-to-br from-slate-50 to-slate-100/50",
      "transition-all duration-300 ease-out",
      "hover:border-blue-400/70 hover:shadow-lg hover:shadow-blue-500/15",
      "hover:from-slate-100 hover:to-slate-200/70",
      "dark:border-slate-700/60 dark:bg-gradient-to-br dark:from-slate-900/60 dark:to-slate-800/40",
      "dark:hover:border-blue-400/50 dark:hover:shadow-xl dark:hover:shadow-blue-500/20",
      "dark:hover:from-slate-800 dark:hover:to-slate-700/60",
      "group",
    ]}
  >
    <div class="flex items-start justify-between gap-4">
      {/* Left: Repo Info */}
      <div class="flex-1 min-w-0">
        {/* Repository Name with GitHub Icon */}
        <div class="flex items-center gap-2.5 mb-3">
          <svg
            class="w-6 h-6 flex-shrink-0 text-slate-800 dark:text-slate-300"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          <h3 class="text-base font-bold text-slate-900 dark:text-white truncate hover:text-blue-600 dark:hover:text-blue-400 transition-colors m-0">
            {repoData.name}
          </h3>
        </div>

        {/* Description */}
        {repoData.description && (
          <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2 mb-3 leading-relaxed">
            {repoData.description}
          </p>
        )}

        {/* Metadata: Languages, Stars */}
        <div class="flex flex-wrap items-center gap-4 text-xs font-medium text-slate-600 dark:text-slate-400">
          {/* Show top 2 languages */}
          {languages.length > 0 ? (
            <>
              {languages.map((lang) => (
                <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-slate-200/40 dark:bg-slate-700/40">
                  <div
                    class="w-2.5 h-2.5 rounded-full"
                    style={`background-color: ${getLanguageColor(lang)}`}
                  />
                  <span class="text-slate-700 dark:text-slate-300">{lang}</span>
                </div>
              ))}
            </>
          ) : repoData.language ? (
            <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-slate-200/40 dark:bg-slate-700/40">
              <div
                class="w-2.5 h-2.5 rounded-full"
                style={`background-color: ${getLanguageColor(repoData.language)}`}
              />
              <span class="text-slate-700 dark:text-slate-300">{repoData.language}</span>
            </div>
          ) : null}

          <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-amber-100/40 dark:bg-amber-900/20">
            <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2l-2.81 6.63L2 9.24l5.46 4.73L5.82 21z" />
            </svg>
            <span class="text-amber-800 dark:text-amber-300">{formatStars(repoData.stargazers_count)}</span>
          </div>
        </div>
      </div>

      {/* Right: Arrow Icon */}
      <svg
        class="w-5 h-5 flex-shrink-0 mt-1 text-slate-400 dark:text-slate-500 transition-all duration-300 group-hover:text-blue-500 dark:group-hover:text-blue-400 group-hover:translate-x-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
        />
      </svg>
    </div>
  </a>
) : (
  <div class="not-prose my-6 rounded-xl border border-slate-200/60 bg-gradient-to-br from-slate-50 to-slate-100/50 p-5 text-sm text-slate-600 dark:border-slate-700/60 dark:bg-gradient-to-br dark:from-slate-900/60 dark:to-slate-800/40 dark:text-slate-400">
    <div class="flex items-center gap-2">
      <div class="w-4 h-4 rounded-full border-2 border-slate-300 border-t-blue-500 dark:border-slate-600 dark:border-t-blue-400 animate-spin"/>
      Loading repository data...
    </div>
  </div>
)}

<style>
  .github-embed {
    --color-text: #e2e8f0;
    --color-border: #475569;
  }
</style>
