---
/**
 * GitHubEmbed — Display a GitHub repository card inline in MDX posts.
 *
 * Usage in .mdx files:
 *   <GitHubEmbed repo="username/repo-name" />
 *
 * Props:
 *   repo      — GitHub repository in format "username/repo-name" (required)
 *
 * Features:
 *   - Fetches live repo data from GitHub API
 *   - Shows repository name, description, stars, language, and link
 *   - Responsive card design with hover effects
 */

type Props = {
  repo: string;
};

interface GitHubRepo {
  name: string;
  description: string | null;
  html_url: string;
  stargazers_count: number;
  language: string | null;
  topics: string[];
}

const { repo } = Astro.props;

// Validate repo format
if (!repo || !repo.includes("/")) {
  throw new Error(`GitHubEmbed: Invalid repo format. Use "username/repo-name"`);
}

// Fetch repository data from GitHub API
let repoData: GitHubRepo | null = null;
let error: string | null = null;

try {
  const response = await fetch(`https://api.github.com/repos/${repo}`, {
    headers: {
      Accept: "application/vnd.github.v3+json",
    },
  });

  if (!response.ok) {
    error = `Repository "${repo}" not found (${response.status})`;
  } else {
    repoData = await response.json();
  }
} catch (e) {
  error = `Failed to fetch repository data: ${String(e)}`;
  console.error(error);
}

// Format star count (1000+ → "1K")
const formatStars = (count: number): string => {
  if (count >= 1000) return `${(count / 1000).toFixed(1)}K`;
  return count.toString();
};

// Get language color
const getLanguageColor = (language: string | null): string => {
  const colors: Record<string, string> = {
    TypeScript: "#3178c6",
    JavaScript: "#f1e05a",
    Python: "#3572a5",
    Rust: "#dea584",
    Go: "#00add8",
    Java: "#b07219",
    "C++": "#f34b7d",
    "C#": "#239120",
    CSS: "#563d7c",
    HTML: "#e34c26",
  };
  return colors[language || ""] || "#888888";
};
---

{
  error ? (
    <div class="not-prose my-4 rounded-lg border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-400">
      <strong>GitHubEmbed Error:</strong> {error}
    </div>
  ) : repoData ? (
    <a
      href={repoData.html_url}
      target="_blank"
      rel="noopener noreferrer"
      class:list={[
        "github-embed not-prose block my-4 rounded-lg p-4",
        "border border-slate-700/50 bg-slate-900/40",
        "transition-all duration-300 ease-out",
        "hover:border-blue-500/50 hover:bg-slate-800/60",
        "hover:shadow-lg hover:shadow-blue-500/10",
      ]}
    >
      <div class="flex items-start justify-between gap-3">
        {/* Left: Repo Info */}
        <div class="flex-1 min-w-0">
          {/* Repository Name */}
          <div class="flex items-center gap-2 mb-2">
            <svg
              class="w-5 h-5 text-slate-400 flex-shrink-0"
              fill="currentColor"
              viewBox="0 0 16 16"
            >
              <path d="M2 2.5A2.5 2.5 0 015 5v3h6V5a2.5 2.5 0 013-2.5h3.5a.5.5 0 01.5.5v9a.5.5 0 01-.5.5H9.5a.5.5 0 01-.5-.5V8H5v6.5a.5.5 0 01-.5.5H1.5a.5.5 0 01-.5-.5v-9a.5.5 0 01.5-.5H2z" />
            </svg>
            <h3 class="text-sm font-semibold text-white truncate hover:text-blue-400 transition-colors">
              {repoData.name}
            </h3>
          </div>

          {/* Description */}
          {repoData.description && (
            <p class="text-xs text-slate-400 line-clamp-2 mb-2">
              {repoData.description}
            </p>
          )}

          {/* Metadata: Language, Stars, Topics */}
          <div class="flex flex-wrap items-center gap-3 text-xs text-slate-400">
            {repoData.language && (
              <div class="flex items-center gap-1.5">
                <div
                  class="w-2 h-2 rounded-full"
                  style={`background-color: ${getLanguageColor(repoData.language)}`}
                />
                <span>{repoData.language}</span>
              </div>
            )}

            <div class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 .5a.5.5 0 01.577.416l.385 1.99h2.097a.5.5 0 01.09.992l-1.95.182.6 1.933a.5.5 0 11-.96.268l-.444-1.427-1.4 1.4a.5.5 0 11-.707-.707l1.4-1.4-.427.427A.5.5 0 015.5 4a.5.5 0 01-.474-.658l.6-1.933-1.95-.182a.5.5 0 01.09-.992h2.097l.385-1.99A.5.5 0 018 .5z" />
              </svg>
              <span>{formatStars(repoData.stargazers_count)}</span>
            </div>
          </div>
        </div>

        {/* Right: Arrow Icon */}
        <svg
          class="w-4 h-4 text-slate-400 flex-shrink-0 mt-1 transition-transform group-hover:translate-x-0.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
          />
        </svg>
      </div>
    </a>
  ) : (
    <div class="not-prose my-4 rounded-lg border border-slate-700/50 bg-slate-900/40 p-4 text-sm text-slate-400">
      Loading repository data...
    </div>
  )
}

<style>
  .github-embed {
    --color-text: #e2e8f0;
    --color-border: #475569;
  }
</style>
